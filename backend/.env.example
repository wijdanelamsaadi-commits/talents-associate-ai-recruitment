PROJECT_NAME="Talents Associate AI Recruitment Platform"
API_VERSION="0.1.0"
API_PREFIX="/api"
ENVIRONMENT="development"

POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="talents_associate_ai"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"

# Optional full SQLAlchemy-compatible PostgreSQL URL.
# DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/talents_associate_ai"

# Use a JSON-style list for multiple frontend origins:
# CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'

# Change this in production.
JWT_SECRET_KEY="change-this-secret-key"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional LLM CV parsing. When disabled or missing an API key, the backend
# automatically uses the built-in heuristic parser.
LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_MODEL=
LLM_ENABLED=false
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Optional candidate notification emails. When disabled or incomplete, email
# logs are still created with status=skipped and business workflows continue.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="Talents Associate"
EMAIL_ENABLED=false
